  "tableLineage": [
    {
      "id": "ln-001",
      "fromTableId": "tbl-001",
      "toTableId": "tbl-003",
      "relationship": "触发报警",
      "fromFields": ["alarm_level", "pipe_id"],
      "toFields": ["alarm_level", "pipe_id"],
      "sqlExample": "INSERT INTO alarm_records SELECT * FROM realtime_pressure WHERE pressure_value > threshold"
    },
    {
      "id": "ln-002",
      "fromTableId": "tbl-007",
      "toTableId": "tbl-008",
      "relationship": "小时汇总",
      "fromFields": ["monitor_point_id", "ph_value", "turbidity", "chlorine_residual"],
      "toFields": ["monitor_point_id", "hour_key", "avg_ph", "max_turbidity"],
      "sqlExample": "INSERT INTO water_quality_hourly SELECT monitor_point_id, DATE_FORMAT(collect_time,'%Y-%m-%d %H') as hour_key, AVG(ph_value), MAX(turbidity) FROM water_quality_raw GROUP BY 1,2"
    },
    {
      "id": "ln-003",
      "fromTableId": "tbl-011",
      "toTableId": "tbl-012",
      "relationship": "生成账单",
      "fromFields": ["meter_id", "reading_value"],
      "toFields": ["customer_id", "water_usage"],
      "sqlExample": "INSERT INTO billing_record SELECT c.customer_id, b.billing_period, (b.reading_value - a.reading_value) as water_usage FROM billing_record a, meter_reading b, customer_info c WHERE a.meter_id = b.meter_id"
    },
    {
      "id": "ln-004",
      "fromTableId": "tbl-010",
      "toTableId": "tbl-011",
      "relationship": "客户关联",
      "fromFields": ["customer_id", "meter_id", "dma_zone_id"],
      "toFields": ["customer_id", "meter_id"],
      "sqlExample": "SELECT m.* FROM meter_reading m JOIN customer_info c ON m.meter_id = c.meter_id"
    },
    {
      "id": "ln-005",
      "fromTableId": "tbl-013",
      "toTableId": "tbl-014",
      "relationship": "分区计量汇总",
      "fromFields": ["zone_id", "zone_name"],
      "toFields": ["zone_id", "zone_name"],
      "sqlExample": "INSERT INTO dma_flow_night SELECT zone_id, zone_name FROM dma_zone"
    },
    {
      "id": "ln-006",
      "fromTableId": "tbl-014",
      "toTableId": "tbl-015",
      "relationship": "漏损分析",
      "fromFields": ["zone_id", "night_flow"],
      "toFields": ["zone_id", "suspect_level"],
      "sqlExample": "INSERT INTO leak_suspect SELECT zone_id, CASE WHEN night_flow > threshold THEN 'HIGH' ELSE 'NORMAL' END FROM dma_flow_night"
    },
    {
      "id": "ln-007",
      "fromTableId": "tbl-001",
      "toTableId": "tbl-004",
      "relationship": "设备关联",
      "fromFields": ["sensor_code"],
      "toFields": ["device_id"],
      "sqlExample": "UPDATE device_status d SET d.online_status = 1 FROM realtime_pressure p WHERE p.sensor_code = d.device_id"
    }
  ]
}
